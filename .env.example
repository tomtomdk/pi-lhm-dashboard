# Copy this file to .env for local testing, or copy these values into your systemd service.

# LibreHardwareMonitor Remote Web Server JSON endpoint on your Windows PC.
# Example: http://192.168.1.50:8085/data.json
LHM_URL=http://YOUR_PC_IP:8085/data.json

# Dashboard web server port on the Raspberry Pi.
PORT=3030

# Offline weather fallback location.
# Open-Meteo uses latitude/longitude and does not require an API key.
WEATHER_LOCATION=Your City
WEATHER_LAT=55.6761
WEATHER_LON=12.5683
WEATHER_TZ=Europe/Copenhagen

# Optional ADA balance display.
# Preferred: read-only Coinbase Advanced Trade / CDP API key with portfolio/account read access only.
# Never commit your real key or private key.
COINBASE_API_KEY_NAME=organizations/YOUR_ORG_ID/apiKeys/YOUR_KEY_ID
COINBASE_API_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END EC PRIVATE KEY-----"
CRYPTO_QUOTE_CURRENCY=DKK

# Optional fallback if you only want to show a manually configured ADA amount.
# When this is set, the dashboard skips Coinbase account lookup and only fetches ADA price.
# ADA_BALANCE_MANUAL=123.45
