# Copy this file to .env for local testing, or copy these values into your systemd service.

# LibreHardwareMonitor Remote Web Server JSON endpoint on your Windows PC.
# Example: http://192.168.1.50:8085/data.json
LHM_URL=http://YOUR_PC_IP:8085/data.json

# Dashboard web server port on the Raspberry Pi.
PORT=3030

# Offline weather fallback location.
# Open-Meteo uses latitude/longitude and does not require an API key.
WEATHER_LOCATION=Your City
WEATHER_LAT=55.6761
WEATHER_LON=12.5683
WEATHER_TZ=Europe/Copenhagen
